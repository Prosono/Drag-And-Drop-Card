{
  "version": 3,
  "options": {
    "storage_key": "ddc_starter_pack_dashboard",
    "grid": 20,
    "drag_live_snap": true,
    "auto_save": true,
    "auto_save_debounce": 700,
    "disable_overlap": false,
    "debug": false,
    "container_size_mode": "fixed_custom",
    "container_fixed_width": 1440,
    "container_fixed_height": 900,
    "container_preset": "fhd",
    "container_preset_orientation": "landscape",
    "auto_resize_cards": true,
    "optimize_for_mobile": true,
    "mobile_dynamic_behavior": "scale",
    "do_not_resize_text": false,
    "outer_grid_buffer": true,
    "responsive_viewports": {
      "desktop": {
        "landscape": {
          "width": 1440,
          "height": 900
        }
      },
      "tablet": {
        "landscape": {
          "width": 1180,
          "height": 820
        },
        "portrait": {
          "width": 820,
          "height": 1180
        }
      },
      "mobile": {
