    {
      "id": "sp_home_quick",
      "card": {
        "type": "custom:ddc-html-card",
        "title": "Command Surface",
        "html": "<div class=\"deck\"><div class=\"pulse\"></div><div><strong>House Core</strong><span id=\"state\"></span></div></div><div class=\"actions\"><button data-setting=\"screen_saver_enabled\">Saver</button><button data-setting=\"animate_cards\">Motion</button><button data-setting=\"layers_enabled\">Layers</button></div>",
        "css": ".deck{display:grid;grid-template-columns:54px 1fr;gap:16px;align-items:center}.deck strong{display:block;font-size:22px;letter-spacing:.02em}.deck span{display:block;margin-top:4px;color:rgba(238,245,239,.66);font-size:13px}.pulse{width:52px;height:52px;border-radius:50%;background:radial-gradient(circle,#f4f7f4 0 9%,#14b8a6 10% 32%,rgba(20,184,166,.18) 33% 100%);box-shadow:0 0 34px rgba(20,184,166,.34)}.actions{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:28px}.actions button{border:1px solid rgba(210,221,207,.15);border-radius:12px;padding:15px 10px;background:linear-gradient(180deg,rgba(244,247,244,.09),rgba(244,247,244,.025));color:#eef5ef;font-weight:700;letter-spacing:.02em;cursor:pointer}.actions button:hover{border-color:rgba(20,184,166,.46);background:rgba(20,184,166,.16)}",
        "js": "const render=()=>{const on=(k)=>ddc.settings.get(k)?'on':'off';root.querySelector('#state').textContent=`Saver ${on('screen_saver_enabled')} | Motion ${on('animate_cards')} | Layers ${on('layers_enabled')}`};root.querySelectorAll('button[data-setting]').forEach(btn=>btn.addEventListener('click',async()=>{await ddc.settings.toggle(btn.dataset.setting,{persist:true});render()}));const off=ddc.settings.subscribe(render);render();return()=>off();",
        "rerun_on_hass_update": false
      },
