  "packages": [
    {
      "id": "ddc_starter_pack_helpers",
      "name": "DDC Starter Pack Helpers",
      "filename": "ddc_starter_pack_helpers.yaml",
      "enabled": true,
      "yaml": "input_boolean:\n  ddc_starter_security_armed:\n    name: Starter Security Armed\n    icon: mdi:shield-home\n  ddc_starter_front_door:\n    name: Starter Front Door\n    icon: mdi:door\n  ddc_starter_motion_detected:\n    name: Starter Motion Detected\n    icon: mdi:motion-sensor\n  ddc_starter_all_lights:\n    name: Starter All Lights\n    icon: mdi:lightbulb-group\n  ddc_starter_climate_eco:\n    name: Starter Climate Eco\n    icon: mdi:leaf\n  ddc_starter_guest_mode:\n    name: Starter Guest Mode\n    icon: mdi:account-multiple\n  ddc_starter_media_night:\n    name: Starter Media Night\n    icon: mdi:weather-night\n\ninput_number:\n  ddc_starter_brightness:\n    name: Starter Brightness\n    min: 0\n    max: 100\n    step: 1\n    unit_of_measurement: \"%\"\n    icon: mdi:brightness-6\n  ddc_starter_temperature:\n    name: Starter Target Temperature\n    min: 15\n    max: 25\n    step: 0.5\n    unit_of_measurement: \"\\u00b0C\"\n    icon: mdi:thermostat\n  ddc_starter_energy_today:\n    name: Starter Energy Today\n    min: 0\n    max: 60\n    step: 0.1\n    unit_of_measurement: \"kWh\"\n    icon: mdi:flash\n\ninput_select:\n  ddc_starter_home_mode:\n    name: Starter Home Mode\n    options:\n      - Home\n      - Away\n      - Night\n      - Guest\n    icon: mdi:home-automation\n  ddc_starter_light_scene:\n    name: Starter Light Scene\n    options:\n      - Relax\n      - Bright\n      - Movie\n      - Night\n    icon: mdi:palette\n  ddc_starter_media_scene:\n    name: Starter Media Scene\n    options:\n      - TV\n      - Music\n      - Movie\n      - Off\n    icon: mdi:play-box\n\ntemplate:\n  - sensor:\n      - name: DDC Starter Outdoor Temperature\n        unique_id: ddc_starter_outdoor_temperature\n        unit_of_measurement: \"\\u00b0C\"\n        state: \"{{ 18 }}\"\n      - name: DDC Starter Humidity\n        unique_id: ddc_starter_humidity\n        unit_of_measurement: \"%\"\n        state: \"{{ 42 }}\"\n"
    }
  ]
